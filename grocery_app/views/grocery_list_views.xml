<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_grocery_list_list" model="ir.ui.view">
        <field name="name">grocery.list.list</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <list string="Grocery Lists" 
                  decoration-muted="status == 'draft'"
                  decoration-info="status == 'in_progress'"
                  decoration-success="status == 'completed'">
                <field name="name"/>
                <field name="responsible_user_id" widget="many2one_avatar_user"/>
                <field name="status" 
                       widget="badge"
                       decoration-muted="status == 'draft'"
                       decoration-info="status == 'in_progress'"
                       decoration-success="status == 'completed'"/>
                <field name="item_count"/>
                <field name="purchased_count"/>
                <field name="pending_count"/>
                <field name="completion_percentage" widget="progressbar"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_grocery_list_form" model="ir.ui.view">
        <field name="name">grocery.list.form</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <form string="Grocery List">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                    <button name="action_start_progress"
                            string="Start Shopping"
                            type="object"
                            class="oe_highlight"
                            invisible="status != 'draft'"/>
                    <button name="action_complete"
                            string="Complete List"
                            type="object"
                            class="oe_highlight"
                            invisible="status != 'in_progress'"
                            confirm="Are you sure all items have been purchased?"/>
                    <button name="action_back_to_progress"
                            string="Reopen"
                            type="object"
                            invisible="status != 'completed'"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="status == 'draft'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-archive"
                                invisible="1">
                            <field name="active" widget="boolean_button"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Weekly Groceries"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="responsible_user_id" widget="many2one_avatar_user"/>
                        </group>
                        <group>
                            <field name="item_count"/>
                            <field name="purchased_count"/>
                            <field name="pending_count"/>
                            <field name="completion_percentage" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items" name="items">
                            <field name="item_ids" widget="one2many">
                                <list string="Grocery Items"
                                      editable="bottom"
                                      decoration-muted="purchased == True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="purchased"
                                           widget="boolean_toggle"
                                           readonly="responsible_user_id != uid"/>
                                    <field name="responsible_user_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Statistics" name="statistics">
                            <group>
                                <group string="Progress">
                                    <field name="item_count" readonly="1"/>
                                    <field name="purchased_count" readonly="1"/>
                                    <field name="pending_count" readonly="1"/>
                                    <field name="completion_percentage" widget="percentpie" readonly="1"/>
                                </group>
                                <group string="Information">
                                    <field name="create_date" readonly="1"/>
                                    <field name="write_date" readonly="1"/>
                                    <field name="create_uid" readonly="1"/>
                                    <field name="write_uid" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_grocery_list_search" model="ir.ui.view">
        <field name="name">grocery.list.search</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <search string="Search Grocery Lists">
                <field name="name" string="List Name"/>
                <field name="responsible_user_id"/>
                <field name="status"/>
                <filter string="My Lists" name="my_lists" domain="[('responsible_user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress" domain="[('status', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <separator/>
                <filter string="Incomplete Lists" 
                        name="incomplete" 
                        domain="[('status', 'in', ['draft', 'in_progress'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Responsible User"
                            name="group_responsible"
                            context="{'group_by': 'responsible_user_id'}"/>
                    <filter string="Status"
                            name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Creation Date"
                            name="group_create_date"
                            context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_grocery_list" model="ir.actions.act_window">
        <field name="name">Grocery Lists</field>
        <field name="res_model">grocery.list</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_lists': 1, 'search_default_incomplete': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first grocery list</p>
            <p>Start managing your grocery shopping by creating lists, adding products, and tracking your purchases.</p>
        </field>
    </record>
</odoo>
