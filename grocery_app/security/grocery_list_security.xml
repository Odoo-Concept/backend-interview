<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Grocery List: Read Access for All Users -->
        <record id="grocery_list_rule_all_read" model="ir.rule">
            <field name="name">All Users: Read All Grocery Lists</field>
            <field name="model_id" ref="model_grocery_list"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Grocery List: Write Access for Own Lists -->
        <record id="grocery_list_rule_own_write" model="ir.rule">
            <field name="name">Users: Modify Own Grocery Lists</field>
            <field name="model_id" ref="model_grocery_list"/>
            <field name="domain_force">['|', ('responsible_user_id', '=', user.id), ('responsible_user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Grocery List Item: Read Access for All Users -->
        <record id="grocery_list_item_rule_all_read" model="ir.rule">
            <field name="name">All Users: Read All Grocery List Items</field>
            <field name="model_id" ref="model_grocery_list_item"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Grocery List Item: Write Access for Own Lists -->
        <record id="grocery_list_item_rule_own_write" model="ir.rule">
            <field name="name">Users: Modify Items of Own Lists</field>
            <field name="model_id" ref="model_grocery_list_item"/>
            <field name="domain_force">['|', ('responsible_user_id', '=', user.id), ('responsible_user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
