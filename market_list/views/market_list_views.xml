<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="market_list_tree_view" model="ir.ui.view">
        <field name="name">market.list.tree.view</field>
        <field name="model">market.list</field>
        <field name="arch" type="xml">
            <list string="Market List">
                <field name="name"/>
                <field name="date"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="market_list_form_view" model="ir.ui.view">
        <field name="name">market.list.form.view</field>
        <field name="model">market.list</field>
        <field name="arch" type="xml">
            <form string="Market List">
                <header>
                    <button name="action_confirm_purchase"
                        type="object"
                        string="Confirm Purchase"
                        class="btn-primary"
                        invisible="state != 'done' or is_confirmed == True"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group class="col-4" >
                            <field name="name" readonly="is_confirmed"/>
                            <field name="date" readonly="is_confirmed"/>
                        </group>
                         <group class="col-4">
                            <field name="responsible_id" widget="many2one_avatar_user" options="{'no_create': True}" readonly="is_confirmed"/>
                             <field name="is_confirmed" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="product_ids" widget="one2many" readonly="is_confirmed">
                                <list editable="bottom">
                                    <field name="product_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="quantity"/>
                                    <field name="is_purchased" widget="checkbox"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
