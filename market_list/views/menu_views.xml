<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_market_list" model="ir.actions.act_window">
        <field name="name">Market List</field>
        <field name="res_model">market.list</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="market_list_tree_view" />
    </record>

    <menuitem
        id="market_list_root_menu"
        name="Market List"
        sequence="1"
        web_icon="enrollment_management,static/description/shopping-list.png"
    />
    <menuitem
        id="market_list_menu"
        name="Market List"
        parent="market_list_root_menu"
        action="market_list.action_market_list"
    />
</odoo>
