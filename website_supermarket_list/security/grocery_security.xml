<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <!-- Record Rules for Grocery Store -->
    <record id="grocery_store_rule_portal" model="ir.rule">
        <field name="name">Grocery Store: Portal users can read all</field>
        <field name="model_id" ref="model_grocery_store" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
    </record>

    <record id="grocery_store_rule_user" model="ir.rule">
        <field name="name">Grocery Store: Internal users can read all</field>
        <field name="model_id" ref="model_grocery_store" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
    </record>

    <!-- Record Rules for Grocery Product -->
    <record id="grocery_product_rule_portal" model="ir.rule">
        <field name="name">Grocery Product: Portal users can read all, edit own</field>
        <field name="model_id" ref="model_grocery_product" />
        <field
            name="domain_force"
        >['|', ('create_uid', '=', user.id), ('create_uid', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
    </record>

    <record id="grocery_product_rule_user" model="ir.rule">
        <field
            name="name"
        >Grocery Product: Internal users can read all, edit own</field>
        <field name="model_id" ref="model_grocery_product" />
        <field
            name="domain_force"
        >['|', ('create_uid', '=', user.id), ('create_uid', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
    </record>

    <!-- Record Rules for Grocery List -->
    <record id="grocery_list_rule_portal" model="ir.rule">
        <field name="name">Grocery List: Portal users can only see own lists</field>
        <field name="model_id" ref="model_grocery_list" />
        <field name="domain_force">[('responsible_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
    </record>

    <record id="grocery_list_rule_user" model="ir.rule">
        <field name="name">Grocery List: Internal users can see all, edit own</field>
        <field name="model_id" ref="model_grocery_list" />
        <field
            name="domain_force"
        >['|', ('responsible_id', '=', user.id), ('responsible_id', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
    </record>

    <!-- Record Rules for Grocery List Line -->
    <record id="grocery_list_line_rule_portal" model="ir.rule">
        <field
            name="name"
        >Grocery List Line: Portal users can only see own list lines</field>
        <field name="model_id" ref="model_grocery_list_line" />
        <field name="domain_force">[('list_id.responsible_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
    </record>

    <record id="grocery_list_line_rule_user" model="ir.rule">
        <field
            name="name"
        >Grocery List Line: Internal users can see all, edit own</field>
        <field name="model_id" ref="model_grocery_list_line" />
        <field
            name="domain_force"
        >['|', ('list_id.responsible_id', '=', user.id), ('list_id.responsible_id', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]" />
    </record>
</odoo>
