<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="demo_store_walmart" model="grocery.store">
        <field name="name">Walmart</field>
        <field
            name="description"
        >Large retail chain offering groceries, household items, and more</field>
        <field name="address">123 Main Street, City Center</field>
        <field name="website">https://www.walmart.com</field>
        <field name="phone">+1 555-0100</field>
        <field name="email">info@walmart.com</field>
        <field name="active" eval="True" />
    </record>

