<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="grocery_list_form_view" model="ir.ui.view">
        <field name="name">grocery.list.form.view</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <form string="Grocery List">
                <header>
                    <button name="action_set_in_progress" string="Start Purchase" class="oe_highlight"
                            type="object" data-hotkey="q"
                            invisible="state != 'draft'"/>
                    <button name="action_set_done" string="Finish Grocery List" class="oe_highlight"
                            type="object" data-hotkey="q"
                            invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
<!--                    <div class="oe_title">-->
<!--                        <span class="o_form_label">Grocery List</span>-->
<!--                        <h1 class="d-flex">-->
<!--                            <field name="name"/>-->
<!--                        </h1>-->
<!--                        <group>-->
<!--                            <field name="user_responsible_id"/>-->
<!--                        </group>-->
<!--                    </div>-->
                    <group>
                        <field name="user_responsible_id"/>
                    </group>
                    <notebook>
                        <page name="grocery_lines_tab" string="Grocery Lines">
                            <field name="grocery_lines" mode="list">
                            <list editable="bottom" string="Grocery Lines">
                                <field name="product_id"/>
                                <field name="product_uom_id"/>
                                <field name="quantity"/>
                                <field name="can_edit_is_purchased" column_invisible="True"/>
                                <field name="is_purchased" readonly="can_edit_is_purchased == False"/>
                            </list>
                        </field>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="grocery_list_tree" model="ir.ui.view">
        <field name="name">grocery.list</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <list string="Grocery List" sample="1">
                <field name="name"/>
                <field name="user_responsible_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="grocery_list_action" model="ir.actions.act_window">
        <field name="name">Grocery List</field>
        <field name="res_model">grocery.list</field>
        <field name="view_mode">list,form</field>
        <field name="usage">menu</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_neutral_face">
                This is the grocery list app
            </p><p>
                Create a new grocery list<br/>
            </p>
        </field>
    </record>


    <menuitem name="Grocery List App"
        id="menu_grocery_list"
        web_icon="jose_manuel_pizarro_interview,static/description/icon.png"
        sequence="75">
        <menuitem id="menu_grocery_list_tree" name="Grocery List" action="grocery_list_action" sequence="1"/>
    </menuitem>
</odoo>
