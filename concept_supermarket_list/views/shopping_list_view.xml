<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- List View for Shopping Lists -->
    <record id="shopping_list_list_view" model="ir.ui.view">
        <field name="name">shopping.list.list</field>
        <field name="model">shopping.list</field>
        <field name="arch" type="xml">
            <list string="Shopping Lists">
                <field name="name" string="Name" />
                <field name="responsible_id" string="Responsible" />
                <field name="state" string="State" />
            </list>
        </field>
    </record>

    <!-- Form View for Shopping List - Main View -->
    <record id="shopping_list_form_view" model="ir.ui.view">
        <field name="name">shopping.list.form</field>
        <field name="model">shopping.list</field>
        <field name="arch" type="xml">
            <form string="Shopping List">
                <!-- Header with Action Buttons -->
                <header>
                    <button
                        name="action_in_progress"
                        type="object"
                        string="Start"
                        class="oe_highlight"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_completed"
                        type="object"
                        string="Done"
                        class="oe_highlight"
                        invisible="state != 'in_progress'"
                    />
                    <button
                        name="action_draft"
                        type="object"
                        string="Back to Draft"
                        invisible="state == 'draft'"
                    />
                    <button
                        name="action_reset"
                        type="object"
                        string="Reset"
                        invisible="state != 'completed'"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,in_progress,completed"
                    />
                </header>

                <sheet>
                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field
                                name="name"
                                placeholder="List Name..."
                                class="oe_inline"
                            />
                        </h1>
                    </div>

                    <!-- Responsible -->
                    <group>
                        <field
                            name="responsible_id"
                            required="1"
                            readonly="state != 'draft'"
                        />
                    </group>

                    <!-- Items Section -->
                    <notebook>
                        <page name="items_page" string="Items">
                            <field
                                name="item_ids"
                                nolabel="1"
                                readonly="state == 'completed'"
                            >
                                <list editable="bottom">
                                    <field
                                        name="product_id"
                                        string="Product"
                                        readonly="parent.state != 'draft'"
                                        required="1"
                                    />
                                    <field
                                        name="quantity"
                                        string="Qty"
                                        readonly="parent.state != 'draft'"
                                        required="1"
                                    />
                                    <field
                                        name="unit_id"
                                        string="Unit"
                                        readonly="parent.state != 'draft'"
                                    />
                                    <field name="is_purchased" string="Purchased" />
                                    <field
                                        name="quantity_done"
                                        column_invisible="parent.state == 'draft'"
                                        force_save="1"
                                    />
                                    <field
                                        name="unit_purchased_id"
                                        force_save="1"
                                        column_invisible="parent.state == 'draft'"
                                    />
                                </list>
                            </field>
                        </page>
                        <page name="notes_page" string="Notes">
                            <field
                                name="description"
                                nolabel="1"
                                placeholder="Write your notes here...."
                            />
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <chatter />
            </form>
        </field>
    </record>

    <!-- Search View for Shopping Lists -->
    <record id="shopping_list_search_view" model="ir.ui.view">
        <field name="name">shopping.list.search</field>
        <field name="model">shopping.list</field>
        <field name="arch" type="xml">
            <search string="Shopping Lists">
                <field name="name" string="Name" />
                <field name="responsible_id" string="Responsible" />

                <separator />

                <filter
                    name="filter_draft"
                    string="Draft"
                    domain="[('state', '=', 'draft')]"
                />
                <filter
                    name="filter_in_progress"
                    string="In Progress"
                    domain="[('state', '=', 'in_progress')]"
                />
                <filter
                    name="filter_completed"
                    string="Done"
                    domain="[('state', '=', 'completed')]"
                />

                <separator />

                <filter
                    name="filter_my_lists"
                    string="My Lists"
                    domain="[('responsible_id', '=', uid)]"
                />

                <separator />

                <group expand="0" string="Group By">
                    <filter
                        name="group_responsible"
                        string="Responsible"
                        context="{'group_by': 'responsible_id'}"
                    />
                    <filter
                        name="group_state"
                        string="State"
                        context="{'group_by': 'state'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Action to open Shopping Lists -->
    <record id="shopping_list_action" model="ir.actions.act_window">
        <field name="name">Shopping Lists</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">shopping.list</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="shopping_list_list_view" />
        <field name="search_view_id" ref="shopping_list_search_view" />
        <field name="context">{'search_default_filter_my_lists': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first shopping list
            </p>
            <p>
                Shopping lists help you organize your purchases efficiently.
            </p>
        </field>
    </record>
</odoo>
