<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_supermarket_checklist_item_form" model="ir.ui.view">
        <field name="name">supermarket.checklist.item.form</field>
        <field name="model">supermarket.checklist.item</field>
        <field name="arch" type="xml">
            <form string="Item">
                <sheet>
                    <group>
                        <field name="product_id" />
                        <field name="quantity" widget="number"/>
                        <field name="product_description" invisible="not product_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
