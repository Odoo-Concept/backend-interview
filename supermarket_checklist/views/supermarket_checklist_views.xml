<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list view -->
    <record id="view_supermarket_checklist_list" model="ir.ui.view">
        <field name="name">supermarket.checklist.list</field>
        <field name="model">supermarket.checklist</field>
        <field name="arch" type="xml">
            <list string="Listas de Supermercado">
                <field name="name"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_supermarket_checklist_form" model="ir.ui.view">
        <field name="name">supermarket.checklist.form</field>
        <field name="model">supermarket.checklist</field>
        <field name="arch" type="xml">
            <form string="Lista de Supermercado">
                <header>
                    <button name="add_product" type="object" string="Agregar Producto" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" />
                    <!-- <button name="action_confirm" type="object" string="Confirmar" states="draft" class="oe_highlight"/>
                    <button name="action_done" type="object" string="Marcar como Hecho" states="confirmed"/>
                    <button name="action_cancel" type="object" string="Cancelar" states="draft,confirmed"/> -->
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="item_ids" readonly="state == 'done'">
                                <list string="Productos" edit="0" create="0">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="bought"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_supermarket_checklist" model="ir.actions.act_window">
        <field name="name">Listas de Supermercado</field>
        <field name="res_model">supermarket.checklist</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_supermarket_checklist_list"/>
    </record>

    <!-- Menú -->
    <menuitem id="menu_supermarket_root" name="Supermercado" sequence="20"/>
    <menuitem id="menu_supermarket_checklists" name="Listas de Supermercado" parent="menu_supermarket_root" action="action_supermarket_checklist" sequence="1"/>

</odoo>
