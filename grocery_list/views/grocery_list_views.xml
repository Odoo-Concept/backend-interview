<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para Grocery List -->
    <record id="view_grocery_list_form" model="ir.ui.view">
        <field name="name">grocery.list.form</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_add_item"
                        string="Añadir producto"
                        type="object"
                        icon="fa-plus"
                        class="oe_highlight"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_set_draft"
                        string="Pasar lista a borrador"
                        type="object"
                        icon="fa-pencil"
                        class="btn-info"
                        invisible="state == 'draft'"
                    />
                    <button
                        name="action_set_in_progress"
                        string="Pasar lista a en progreso"
                        type="object"
                        icon="fa-hourglass-half"
                        class="btn-warning"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_set_completed"
                        string="Marcar lista como completada"
                        type="object"
                        icon="fa-check"
                        class="btn-success"
                        invisible="state != 'in_progress'"
                    />
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la lista..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="responsible_id" readonly="responsible_id != uid"/>
                        </group>
                        <group>
                            <field name="item_count"/>
                            <field name="completed_items_count"/>
                            <field name="progress_percentage" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Productos" invisible="not item_ids">
                             <field name="item_ids" readonly="state != 'draft'">
                                <list create="false">
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="is_purchased"/>
                                    <button
                                        name="action_set_purchased"
                                        string="Marcar como comprado"
                                        type="object"
                                        icon="fa-cart-plus"
                                        class="btn-success"
                                        invisible="is_purchased or responsible_id != uid or list_state != 'in_progress'"
                                    />
                                    <button
                                        name="action_remove_purchased"
                                        string="Marcar como no comprado"
                                        type="object"
                                        icon="fa-undo"
                                        class="btn-danger"
                                        invisible="not is_purchased or responsible_id != uid or list_state != 'in_progress'"
                                    />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de lista para Grocery List -->
    <record id="view_grocery_list_list" model="ir.ui.view">
        <field name="name">grocery.list.list</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <list string="Listas de Supermercado">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="item_count"/>
                <field name="completed_items_count"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="create_date"/>
                <field
                    name="state"
                    widget="label_selection"
                    options="{'classes': {'draft': 'info', 'in_progress': 'warning', 'completed': 'success'}}"
                />
            </list>
        </field>
    </record>

    <!-- Vista de búsqueda para Grocery List -->
    <record id="view_grocery_list_search" model="ir.ui.view">
        <field name="name">grocery.list.search</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="state"/>
                <filter string="Mis Listas" name="my_lists" domain="[('responsible_id', '=', uid)]"/>
                <filter string="Borrador" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="En Progreso" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completadas" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Responsable" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                </group>
            </search>
        </field>
    </record>


    <!-- Vista Kanban para Grocery List -->
    <record id="view_grocery_list_kanban" model="ir.ui.view">
        <field name="name">grocery.list.kanban</field>
        <field name="model">grocery.list</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="state"/>
                <field name="item_count"/>
                <field name="completed_items_count"/>
                <field name="progress_percentage"/>
                <kanban>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card p-2">
                                <div class="d-flex mb-2" style="justify-content: space-between;">
                                   <field name="name" class="fw-bolder fs-4"/>
                                   <field
                                        name="state"
                                        widget="label_selection"
                                        options="{'classes': {'draft': 'info', 'in_progress': 'warning', 'completed': 'success'}}"
                                        class="ms-1 fs-4"
                                    />
                               </div>
                                <div class="row text-muted">
                                    <div>
                                        <strong>Responsable</strong>: <field name="responsible_id"/>
                                    </div>
                                    <div>
                                        <strong>Productos comprados</strong>:
                                        <field name="completed_items_count"/> / <field name="item_count"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </kanban>
        </field>
    </record>

    <!-- Action Grocery List -->
    <record id="action_grocery_list" model="ir.actions.act_window">
        <field name="name">Listas de Supermercado</field>
        <field name="res_model">grocery.list</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
