<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_grocery_list_item_list" model="ir.ui.view">
        <field name="name">grocery.list.item.list</field>
        <field name="model">grocery.list.item</field>
        <field name="arch" type="xml">
            <list decoration-success="is_purchased == True" decoration-muted="is_purchased == True">
                <field name="list_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="is_purchased" widget="boolean_toggle" readonly="not can_edit_purchased"/>
            </list>
        </field>
    </record>

    <record id="view_grocery_list_item_form" model="ir.ui.view">
        <field name="name">grocery.list.item.form</field>
        <field name="model">grocery.list.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="list_id"/>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="is_purchased" readonly="not can_edit_purchased"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_grocery_list_item_search" model="ir.ui.view">
        <field name="name">grocery.list.item.search</field>
        <field name="model">grocery.list.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="list_id"/>
                <field name="product_id"/>
                <filter string="Comprados" name="purchased" domain="[('is_purchased', '=', True)]"/>
                <filter string="Sin Comprar" name="not_purchased" domain="[('is_purchased', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_grocery_list_item" model="ir.actions.act_window">
        <field name="name">Items de Lista</field>
        <field name="res_model">grocery.list.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_grocery_list_item_search"/>
    </record>
</odoo>

