<odoo>
    <data>
        <record id="grocery_list_rule_read_all" model="ir.rule">
            <field name="name">Grocery List: read all</field>
            <field name="model_id" ref="model_grocery_list"/>
            <field name="global" eval="False"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_user'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="grocery_list_rule_write_own_or_responsible" model="ir.rule">
            <field name="name">Grocery List: write if creator or responsible</field>
            <field name="model_id" ref="model_grocery_list"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_user'))]"/>
            <field name="domain_force">
                ['|', ('responsible_id', '=', user.id), ('create_uid', '=', user.id)]
            </field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="grocery_list_item_rule_read_all" model="ir.rule">
            <field name="name">Grocery List Item: read all</field>
            <field name="model_id" ref="model_grocery_list_item"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_user'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="grocery_list_item_rule_write_own_or_responsible" model="ir.rule">
            <field name="name">Grocery List Item: write if creator or list responsible</field>
            <field name="model_id" ref="model_grocery_list_item"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_user'))]"/>
            <field name="domain_force">
                ['|', ('create_uid', '=', user.id), ('list_id.responsible_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        
        <record id="grocery_list_rule_manager_all" model="ir.rule">
            <field name="name">Grocery List: managers have full access</field>
            <field name="model_id" ref="model_grocery_list"/>
            <field name="global" eval="False"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_manager'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="grocery_list_item_rule_manager_all" model="ir.rule">
            <field name="name">Grocery List Item: managers have full access</field>
            <field name="model_id" ref="model_grocery_list_item"/>
            <field name="global" eval="False"/>
            <field name="groups" eval="[(4, ref('grocery_list.group_grocery_list_manager'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>