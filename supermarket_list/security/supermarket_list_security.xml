<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_supermarket_list_portal_own" model="ir.rule">
        <field name="name">Portal: own supermarket lists</field>
        <field name="model_id" ref="model_supermarket_list"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
        <field name="domain_force">[('responsible_id', '=', user.id)]</field>
    </record>

    <record id="rule_supermarket_list_line_portal_own" model="ir.rule">
        <field name="name">Portal: own supermarket list items</field>
        <field name="model_id" ref="model_supermarket_list_line"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
        <field name="domain_force">[('list_id.responsible_id', '=', user.id)]</field>
    </record>
</odoo>
