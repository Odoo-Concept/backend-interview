<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list view de listas -->
    <record id="view_supermarket_list_list" model="ir.ui.view">
        <field name="name">supermarket.list.list</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <list string="Listas de supermercado">
                <field name="name"/>
                <field name="description"/>
                <field name="responsible_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_supermarket_list_form" model="ir.ui.view">
        <field name="name">supermarket.list.form</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <form string="Lista de Supermercado">
                <header>
                    <button name="action_set_draft" string="Pasar a Borrador" type="object" invisible="state in ['draft','done']"/>
                    <button name="action_set_progress" string="Confirmar"  class="btn-primary" type="object" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,progress,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="state in ['progress','done']"/>
                        <field name="description" readonly="state in ['progress','done']"/>
                        <field name="responsible_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Ítems">
                            <field name="line_ids" readonly="state in ['done']">
                                <list editable="bottom">
                                    <field name="list_state" column_invisible="1"/>
                                    <field name="product_id" readonly="list_state in ['progress','done']"/>
                                    <field name="quantity" readonly="list_state in ['progress','done']"/>
                                    <field name="purchased_by" readonly="1"/>
                                    <field name="purchased_date" readonly="1"/>
                                    <!-- Botón dinámico -->
                                    <button name="action_toggle_purchased"
                                            string="Marcar compra"
                                            type="object"
                                            class="btn-primary"
                                            invisible="purchased == True or list_state not in ['progress']"/>
                                    <button name="action_toggle_purchased"
                                            string="Regresar compra"
                                            type="object"
                                            class="btn-secondary"
                                            invisible="purchased == False or list_state in ['done']"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas">
                            <field name="note"/>
                        </page>
                    </notebook>
                    <footer>
                        <button string="Borrador" type="object" name="action_set_draft" class="btn-secondary"/>
                        <button string="Iniciar" type="object" name="action_set_progress" class="btn-primary"/>
                        <button string="Completar" type="object" name="action_set_done" class="btn-success"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- list view -->
    <record id="view_supermarket_list_line_list" model="ir.ui.view">
        <field name="name">supermarket.list.line.list</field>
        <field name="model">supermarket.list.line</field>
        <field name="arch" type="xml">
            <list string="Ítems de listas">
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="purchased" eval="{'readonly': [('list_id.state', '!=', 'progress')]}"/>
                <field name="list_id"/>
            </list>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_supermarket_list_kanban" model="ir.ui.view">
        <field name="name">supermarket.list.kanban</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="state"/>
                <field name="note"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card"
                            t-att-class="record.state.raw_value == 'done' and 'o_kanban_color_green' or record.state.raw_value == 'progress' and 'o_kanban_color_yellow' or 'o_kanban_color_gray'">

                            <!-- Encabezado -->
                            <div class="o_kanban_header d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex flex-column">
                                    <strong class="text-lg fw-bold mb-1" t-esc="record.name.value"/>
                                    <span class="badge align-self-start"
                                        t-att-class="record.state.raw_value == 'done' and 'badge bg-success' or record.state.raw_value == 'progress' and 'badge bg-warning' or 'badge bg-secondary'">
                                        <t t-esc="record.state.value"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Responsable -->
                            <div class="o_kanban_body mt-2">
                                <div class="d-flex align-items-center text-muted">
                                    <i class="fa fa-user me-2"/>
                                    <t t-if="record.responsible_id.value">
                                        <span t-esc="record.responsible_id.value"/>
                                    </t>
                                    <t t-else="">
                                        <em>Sin responsable</em>
                                    </t>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción general ver todas las listas -->
    <record id="action_supermarket_list_all" model="ir.actions.act_window">
        <field name="name">Todas las Listas</field>
        <field name="res_model">supermarket.list</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- Acción filtrada ver solo las del usuario actual -->
    <record id="action_supermarket_list_my" model="ir.actions.act_window">
        <field name="name">Mis Listas</field>
        <field name="res_model">supermarket.list</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('responsible_id', '=', uid)]</field>
    </record>

    <!-- Menú principal -->
    <menuitem id="menu_supermarket_root"
              name="Supermarket"
              sequence="1"
              web_icon="supermarket_list,static/description/icon.png"/>

    <!-- Submenú Todas las listas -->
    <menuitem id="menu_supermarket_all_lists"
              name="Todas las Listas"
              parent="menu_supermarket_root"
              action="action_supermarket_list_all"
              sequence="1"/>

    <!-- Submenú Mis listas -->
    <menuitem id="menu_supermarket_my_lists"
              name="Mis Listas"
              parent="menu_supermarket_root"
              action="action_supermarket_list_my"
              sequence="2"/>

</odoo>
