<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View supermarket.list Search -->
    <record id="view_supermarket_list_search" model="ir.ui.view">
        <field name="name">view.supermarket.list.search</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]" />
                <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]" />
                <filter name="done" string="Done" domain="[('state', '=', 'done')]" />
            </search>
        </field>
    </record>

    <!-- View supermarket.list View List -->
    <record id="view_supermarket_list_list" model="ir.ui.view">
        <field name="name">view.supermarket.list.list</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user" />
                <field name="supermarket_line_ids" string="List items"/>
                <field 
                    name="state" 
                    widget="badge" 
                    decoration-info="state == 'draft'" 
                    decoration-warning="state == 'in_progress'"
                    decoration-success="state == 'done'" 
                />
            </list>
        </field>
    </record>

    <!-- View supermarket.list form -->
    <record id="view_supermarket_list_form" model="ir.ui.view">
        <field name="name">view.supermarket.list.form</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <form string="Supermarket List">
                <header>
                    <button 
                        class="oe_highlight"
                        type="object" 
                        name="action_add_product"
                        string="Add product"
                    />
                    <field name="state" widget="statusbar" />                    
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button 
                            invisible="count_products == 0"
                            class="oe_stat_button"
                            type="object" 
                            name="action_go_to_products" 
                            icon="fa-pencil"
                        >
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="count_products"/>
                                </span>
                                <span class="o_stat_text">
                                    Productos
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="user_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                    </group>
                    <group string="List items">
                        <field name="supermarket_line_ids" nolabel="1" colspan="2">                   
                            <list editable="bottom" create="0">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="is_purchased"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action supermarket.list -->
    <record id="action_supermarket_list" model="ir.actions.act_window">
        <field name="name">Supermarket List</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">supermarket.list</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Supermarket List.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_supermarket_list"
        name="Lists"
        action="action_supermarket_list"
        parent="supermarket_list_root_menu"
        sequence="10"
    />

</odoo>
