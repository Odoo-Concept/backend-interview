<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="supermarket_list_view_list" model="ir.ui.view">
        <field name="name">supermarket.list.view.list</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <list string="Supermarket Lists">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="supermarket_list_view_form" model="ir.ui.view">
        <field name="name">supermarket.list.view.form</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <form string="Supermarket List">
                <header>
                    <button name="action_set_draft" type="object" string="Set to Draft" invisible="state == 'draft'"/>
                    <button name="action_start" type="object" string="Start" invisible="state != 'draft'"/>
                    <button name="action_mark_done" type="object" string="Mark Done" invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="List name" nolabel="1"/>
                        </h1>
                    </div>
                    <div class="alert alert-info" role="alert">
                        Only the assigned responsible can mark items as purchased.
                    </div>
                    <group>
                        <group>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="line_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="is_responsible" column_invisible="1"/>
                                    <field name="is_purchased" readonly="not is_responsible"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="supermarket_list_view_search" model="ir.ui.view">
        <field name="name">supermarket.list.view.search</field>
        <field name="model">supermarket.list</field>
        <field name="arch" type="xml">
            <search string="Supermarket Lists">
                <field name="name"/>
                <field name="responsible_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Responsible" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_supermarket_list" model="ir.actions.act_window">
        <field name="name">Supermarket Lists</field>
        <field name="res_model">supermarket.list</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="supermarket_list_view_search"/>
    </record>
</odoo>
