<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View supermarket.list.line Search -->
    <record id="view_supermarket_list_line_search" model="ir.ui.view">
        <field name="name">view.supermarket.list.line.search</field>
        <field name="model">supermarket.list.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="list_id"/>
                <field name="product_id"/>
                <filter name="is_purchased" string="Purchased" domain="[('is_purchased', '=', True)]"/>
                <filter name="isnt_purchased" string="Not Purchased" domain="[('is_purchased', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- View supermarket.list.line View List -->
    <record id="view_supermarket_list_line_list" model="ir.ui.view">
        <field name="name">view.supermarket.list.line.list</field>
        <field name="model">supermarket.list.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="list_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="is_purchased"/>
            </list>
        </field>
    </record>

    <!-- View supermarket.list.line form -->
    <record id="view_supermarket_list_line_form" model="ir.ui.view">
        <field name="name">view.supermarket.list.line.form</field>
        <field name="model">supermarket.list.line</field>
        <field name="arch" type="xml">
            <form string="Supermarket List Line">
                <sheet>
                    <group>
                        <field name="list_id"/>
                        <field name="product_id"/>
                        <field name="quantity"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action supermarket.list.line -->
    <record id="action_supermarket_list_line" model="ir.actions.act_window">
        <field name="name">Supermarket List Line</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">supermarket.list.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Supermarket List Line.
            </p>
        </field>
    </record>

</odoo>
